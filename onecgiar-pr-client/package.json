{
  "name": "onecgiar-pr-client",
  "version": "1.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:dev": "ng build --configuration development",
    "watch": "ng build --watch --configuration development",
    "test": "jest --no-coverage",
    "test:watch": "jest --watch --no-coverage",
    "test:coverage": "jest --coverage",
    "test:coverage:html": "jest --coverage --coverageReporters=text-summary --coverageReporters=cobertura --coverageReporters=lcov",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "tunnel": "ng serve --allowed-hosts true --host 0.0.0.0",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:component": "cypress open --component",
    "test:ct": "cypress run --component"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.18",
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.18",
    "@angular/compiler": "^21.2.18",
    "@angular/core": "^21.2.18",
    "@angular/forms": "^21.2.18",
    "@angular/platform-browser": "^21.2.18",
    "@angular/platform-browser-dynamic": "^21.2.18",
    "@angular/router": "^21.2.18",
    "@hotjar/browser": "^1.0.9",
    "@microsoft/clarity": "^1.0.0",
    "@spartan-ng/brain": "^1.1.0",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "chroma-js": "^3.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "jest": "^29.7.0",
    "jest-preset-angular": "^14.6.0",
    "ng-circle-progress": "^1.7.1",
    "ngx-socket-io": "^4.8.1",
    "pdfjs-dist": "^3.11.174",
    "primeicons": "^7.0.0",
    "pusher-js": "^7.1.0-beta",
    "rxjs": "^7.8.2",
    "tailwind-merge": "^3.5.0",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.19",
    "@angular-eslint/builder": "^21.4.0",
    "@angular-eslint/eslint-plugin": "^21.4.0",
    "@angular-eslint/eslint-plugin-template": "^21.4.0",
    "@angular-eslint/schematics": "^21.4.0",
    "@angular-eslint/template-parser": "^21.4.0",
    "@angular/build": "^21.2.19",
    "@angular/cli": "^21.2.19",
    "@angular/compiler-cli": "^21.2.18",
    "@spartan-ng/cli": "^1.1.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/cypress": "^0.1.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.32",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "cypress": "^14.5.1",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.5.0",
    "prettier": "^3.6.2",
    "prettier-eslint": "^16.4.2",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.0"
  },
  "jest": {
    "preset": "jest-preset-angular",
    "setupFilesAfterEnv": [
      "<rootDir>/src/setup-jest.ts"
    ],
    "transform": {
      "^.+\\.(ts|js|mjs|html|svg)$": [
        "jest-preset-angular",
        {
          "tsconfig": "<rootDir>/tsconfig.spec.json",
          "stringifyContentPathRegex": "\\.(html|svg)$",
          "diagnostics": false
        }
      ]
    },
    "cacheDirectory": "<rootDir>/.jest-cache",
    "maxWorkers": "50%",
    "coverageReporters": [
      "text-summary",
      "cobertura"
    ],
    "collectCoverage": false,
    "collectCoverageFrom": [
      "./src/app/**/*.ts",
      "!./src/app/**/*routing.ts",
      "!./src/app/**/*module.ts",
      "!./src/app/**/model/*.ts",
      "!./src/app/**/models/*.ts",
      "!./src/app/**/routing-data-ipsr.ts",
      "!./src/app/**/routing-data.ts",
      "!./src/app/custom-fields/**/*",
      "!./src/app/pages/results/pages/result-detail/pages/rd-contributors-and-partners/**/*"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/dist/"
    ],
    "moduleNameMapper": {
      "@microsoft/clarity": "<rootDir>/tests/mocks/clarityMock.ts",
      "@spartan/input": "<rootDir>/src/app/spartan/input/src/index.ts",
      "@spartan/utils": "<rootDir>/src/app/spartan/utils/src/index.ts",
      "@spartan/button": "<rootDir>/src/app/spartan/button/src/index.ts",
      "^src/(.*)$": "<rootDir>/src/$1"
    },
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 60,
        "lines": 60,
        "statements": 60
      }
    }
  }
}
