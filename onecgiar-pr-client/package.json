{
  "name": "onecgiar-pr-client",
  "version": "1.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:dev": "ng build --configuration development",
    "watch": "ng build --watch --configuration development",
    "test": "jest --no-coverage",
    "test:watch": "jest --watch --no-coverage",
    "test:coverage": "jest --coverage",
    "test:coverage:html": "jest --coverage --coverageReporters=text-summary --coverageReporters=cobertura --coverageReporters=lcov",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "tunnel": "ng serve --allowed-hosts true --host 0.0.0.0",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:run:record": "cypress run --record --key $CYPRESS_RECORD_KEY"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.7",
    "@angular/cdk": "^22.0.5",
    "@angular/common": "^22.0.7",
    "@angular/compiler": "^22.0.7",
    "@angular/core": "^22.0.7",
    "@angular/forms": "^22.0.7",
    "@angular/platform-browser": "^22.0.7",
    "@angular/platform-browser-dynamic": "^22.0.7",
    "@angular/router": "^22.0.7",
    "@hotjar/browser": "^1.0.9",
    "@microsoft/clarity": "^1.0.0",
    "@ncstate/sat-popover": "^16.0.0",
    "@primeng/themes": "^19.1.3",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "chroma-js": "^3.1.2",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "jest": "^29.7.0",
    "jest-preset-angular": "^17.0.0",
    "ng-circle-progress": "^1.7.1",
    "ngx-socket-io": "^4.11.0",
    "pdfjs-dist": "^3.11.174",
    "primeicons": "^7.0.0",
    "primeng": "^22.0.0",
    "pusher-js": "^7.1.0-beta",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^18.4.3",
    "@angular-eslint/eslint-plugin": "^18.4.3",
    "@angular-eslint/eslint-plugin-template": "^18.4.3",
    "@angular-eslint/schematics": "^18.4.3",
    "@angular-eslint/template-parser": "^18.4.3",
    "@angular/build": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.7",
    "@types/cypress": "^0.1.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.32",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "cypress": "^15.18.1",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.5.0",
    "prettier": "^3.6.2",
    "prettier-eslint": "^16.4.2",
    "typescript": "^5.8.3"
  },
  "jest": {
    "preset": "jest-preset-angular",
    "setupFilesAfterEnv": [
      "<rootDir>/src/setup-jest.ts"
    ],
    "transform": {
      "^.+\\.(ts|js|mjs|html|svg)$": [
        "jest-preset-angular",
        {
          "tsconfig": "<rootDir>/tsconfig.spec.json",
          "stringifyContentPathRegex": "\\.(html|svg)$",
          "diagnostics": false
        }
      ]
    },
    "cacheDirectory": "<rootDir>/.jest-cache",
    "maxWorkers": "50%",
    "coverageReporters": [
      "text-summary",
      "cobertura"
    ],
    "collectCoverage": false,
    "collectCoverageFrom": [
      "./src/app/**/*.ts",
      "!./src/app/**/*routing.ts",
      "!./src/app/**/*module.ts",
      "!./src/app/**/model/*.ts",
      "!./src/app/**/models/*.ts",
      "!./src/app/**/routing-data-ipsr.ts",
      "!./src/app/**/routing-data.ts",
      "!./src/app/custom-fields/**/*",
      "!./src/app/pages/results/pages/result-detail/pages/rd-contributors-and-partners/**/*"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/dist/"
    ],
    "moduleNameMapper": {
      "@microsoft/clarity": "<rootDir>/tests/mocks/clarityMock.ts"
    },
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 60,
        "lines": 60,
        "statements": 60
      }
    }
  }
}
